# SenPrinTech Django email configuration
# Copy this file to .env and replace the values.

SECRET_KEY=replace-with-a-long-random-secret-key
DEBUG=False
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://*.onrender.com
DATABASE_URL=postgresql://user:password@host:5432/dbname
WEB_CONCURRENCY=4

SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SERVE_MEDIA_FILES=True
MEDIA_ROOT=/var/data/mediafiles

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=15

# Gmail address used to send emails.
EMAIL_HOST_USER=papeaboumbaye@gmail.com

# Gmail App Password, not your normal Gmail password.
# Example format: abcd efgh ijkl mnop
EMAIL_HOST_PASSWORD=woxy okwc clvw wkiu

DEFAULT_FROM_EMAIL=SenPrinTech <papeaboumbaye@gmail.com>
QUOTE_ADMIN_EMAIL=papeaboumbaye@gmail.com
